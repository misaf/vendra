TIMEZONE=UTC

APP_NAME=Vendra
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://vendra.test
ASSET_URL=https://vendra.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vendra
DB_USERNAME=vendra
DB_PASSWORD=change-this-app-db-password
DB_ROOT_PASSWORD=change-this-root-db-password

SESSION_DRIVER=redis
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

CACHE_STORE=redis
SETTINGS_CACHE_ENABLED=true
QUEUE_CONNECTION=redis

PUSHER_LOG_LEVEL=error

TURNSTILE_KEY=
TURNSTILE_SECRET=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
